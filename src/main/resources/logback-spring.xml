<?xml version="1.0" encoding="UTF-8"?>
<!--
  Peach 统一 Logback 配置（随 peach-common-start 进入下游工程 classpath）。
  下游无需再提供 logback.xml；若业务自建 logback-spring.xml / logback.xml 且位于主工程 resources 根，将覆盖本文件。
  日志目录默认 ./logs（相对 user.dir），与 peach.logging.file.path 一致。
  默认日志级别由 PeachLoggingEnvironmentPostProcessor 按 profile 注入：pro/produce/product/test → root WARN；
  其余环境 → root INFO，且 peach.logging.dev.debug-packages 下包为 DEBUG（均可用 logging.level.* 覆盖）。
-->
<configuration scan="true" scanPeriod="60 seconds">

	<springProperty scope="context" name="PEACH_LOG_DIR" source="peach.logging.file.path" defaultValue="logs"/>
	<springProperty scope="context" name="PEACH_TRACE_MDC" source="peach.logging.trace.mdc-key" defaultValue="traceId"/>
	<springProperty scope="context" name="PEACH_MAIN_MAX_HISTORY" source="peach.logging.file.main-max-history" defaultValue="30"/>
	<springProperty scope="context" name="PEACH_ERR_MAX_HISTORY" source="peach.logging.file.error-max-history" defaultValue="90"/>
	<springProperty scope="context" name="ROOT_LEVEL" source="logging.level.root" defaultValue="INFO"/>

	<property name="PEACH_LOG_PATTERN"
			  value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - [%X{${PEACH_TRACE_MDC}}] %msg%n"/>

	<contextName>peach</contextName>

	<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>${PEACH_LOG_PATTERN}</pattern>
			<charset>UTF-8</charset>
		</encoder>
	</appender>

	<!-- 全量级别镜像（与控制台策略一致），按天滚动，历史 gzip -->
	<appender name="CONSOLE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${PEACH_LOG_DIR}/console.log</file>
		<encoder>
			<pattern>${PEACH_LOG_PATTERN}</pattern>
			<charset>UTF-8</charset>
		</encoder>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>${PEACH_LOG_DIR}/archive/console.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
			<maxHistory>${PEACH_MAIN_MAX_HISTORY}</maxHistory>
			<cleanHistoryOnStart>false</cleanHistoryOnStart>
		</rollingPolicy>
	</appender>

	<appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${PEACH_LOG_DIR}/error.log</file>
		<filter class="ch.qos.logback.classic.filter.ThresholdFilter">
			<level>ERROR</level>
		</filter>
		<encoder>
			<pattern>${PEACH_LOG_PATTERN}</pattern>
			<charset>UTF-8</charset>
		</encoder>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>${PEACH_LOG_DIR}/archive/error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
			<maxHistory>${PEACH_ERR_MAX_HISTORY}</maxHistory>
			<cleanHistoryOnStart>false</cleanHistoryOnStart>
		</rollingPolicy>
	</appender>

	<root level="${ROOT_LEVEL}">
		<appender-ref ref="CONSOLE"/>
		<appender-ref ref="CONSOLE_FILE"/>
		<appender-ref ref="ERROR_FILE"/>
	</root>
</configuration>
