<?xml version="1.0" encoding="UTF-8"?>
<!--
  Peach 统一 Logback 配置（随 peach-common-start 进入下游工程 classpath）。
  下游无需再提供 logback.xml；若业务自建 logback-spring.xml / logback.xml 且位于主工程 resources 根，将覆盖本文件。

  环境策略（均在本文件维护，避免 EnvironmentPostProcessor 注入 logging.level.*）：
  - 默认（未激活下列生产类 profile）：root INFO；MyBatis、JDBC、org.peach 等为 DEBUG，便于本地与联调看 SQL/业务日志。
  - pro / produce / product / test：root WARN；MyBatis/JDBC 等噪声包降为 WARN。
  - test 额外保留 org.springframework.boot、org.peach.common 为 INFO，避免启动成功/失败结论被降噪后“像没起来”。

  仍可覆盖：业务 application.yml 中 logging.level.*（由 Spring Boot 绑定到 Logback）会作用于对应 logger。
  日志目录与归档天数可选：peach.logging.file.*（由 springProperty 读环境，与 TraceIdFilter 中 MDC 键 traceId 无关）。
  TraceId 请求头/MDC 键固定为 X-Trace-Id / traceId（与 org.peach.common.mvc.logs.web.TraceIdFilter 一致）。
-->
<configuration scan="true" scanPeriod="60 seconds">

	<springProperty scope="context" name="PEACH_LOG_DIR" source="peach.logging.file.path" defaultValue="logs"/>
	<springProperty scope="context" name="PEACH_MAIN_MAX_HISTORY" source="peach.logging.file.main-max-history" defaultValue="30"/>
	<springProperty scope="context" name="PEACH_ERR_MAX_HISTORY" source="peach.logging.file.error-max-history" defaultValue="90"/>

	<!-- 默认 root 级别；生产类 profile 在同名 springProfile 内覆盖为 WARN（后声明的 property 优先生效） -->
	<property name="ROOT_LEVEL" value="INFO"/>
	<springProfile name="pro,produce,product,test">
		<property name="ROOT_LEVEL" value="WARN"/>
	</springProfile>

	<property name="PEACH_LOG_PATTERN"
			  value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - [%X{traceId}] %msg%n"/>

	<contextName>peach</contextName>

	<appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>${PEACH_LOG_PATTERN}</pattern>
			<charset>UTF-8</charset>
		</encoder>
	</appender>

	<appender name="CONSOLE_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${PEACH_LOG_DIR}/console.log</file>
		<encoder>
			<pattern>${PEACH_LOG_PATTERN}</pattern>
			<charset>UTF-8</charset>
		</encoder>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>${PEACH_LOG_DIR}/archive/console.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
			<maxHistory>${PEACH_MAIN_MAX_HISTORY}</maxHistory>
			<cleanHistoryOnStart>false</cleanHistoryOnStart>
		</rollingPolicy>
	</appender>

	<appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<file>${PEACH_LOG_DIR}/error.log</file>
		<filter class="ch.qos.logback.classic.filter.ThresholdFilter">
			<level>ERROR</level>
		</filter>
		<encoder>
			<pattern>${PEACH_LOG_PATTERN}</pattern>
			<charset>UTF-8</charset>
		</encoder>
		<rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
			<fileNamePattern>${PEACH_LOG_DIR}/archive/error.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
			<maxHistory>${PEACH_ERR_MAX_HISTORY}</maxHistory>
			<cleanHistoryOnStart>false</cleanHistoryOnStart>
		</rollingPolicy>
	</appender>

	<!-- 非生产类环境：框架与平台包 DEBUG（下游业务根包可在此追加 <logger name="com.example" level="DEBUG"/>） -->
	<logger name="org.apache.ibatis" level="DEBUG"/>
	<logger name="org.mybatis" level="DEBUG"/>
	<logger name="java.sql" level="DEBUG"/>
	<logger name="org.peach" level="DEBUG"/>

	<springProfile name="pro,produce,product,test">
		<logger name="org.apache.ibatis" level="WARN"/>
		<logger name="org.mybatis" level="WARN"/>
		<logger name="java.sql" level="WARN"/>
		<logger name="org.peach" level="WARN"/>
	</springProfile>

	<!-- test：降噪但保留 Boot 启动结论、Nacos 注册与失败诊断 INFO/ERROR -->
	<springProfile name="test">
		<logger name="org.springframework.boot" level="INFO"/>
		<logger name="org.springframework.boot.web" level="INFO"/>
		<logger name="org.springframework.boot.diagnostics" level="ERROR"/>
		<logger name="org.peach.common" level="INFO"/>
		<logger name="com.alibaba.cloud.nacos" level="INFO"/>
		<logger name="com.alibaba.nacos" level="WARN"/>
	</springProfile>

	<root level="${ROOT_LEVEL}">
		<appender-ref ref="CONSOLE"/>
		<appender-ref ref="CONSOLE_FILE"/>
		<appender-ref ref="ERROR_FILE"/>
	</root>
</configuration>
